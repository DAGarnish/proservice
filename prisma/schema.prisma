datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model WebsiteSubmission {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Step 1 — Business Basics
  business_name         String
  contact_name          String
  phone_number          String
  email_address         String
  business_address      String?  @default("")
  service_area          String?  @default("")
  occupation            String
  years_in_business     String?  @default("")

  // Step 2 — Services
  main_services         String
  specialities          String?  @default("")
  price_list            String?  @default("")
  top_services_to_promote String? @default("")
  emergency_service     Boolean  @default(false)
  main_cta              String   @default("call")

  // Step 3 — Trust & Credibility
  differentiator        String?  @default("")
  qualifications        String?  @default("")
  insurance             Boolean  @default(false)
  memberships           String?  @default("")
  specialist_tools      String?  @default("")
  testimonials          String?  @default("")
  notable_work          String?  @default("")
  guarantees            String?  @default("")

  // Step 4 — Brand & Style
  style_preference      String[]
  preferred_colours     String?  @default("")
  selected_website_look String   @default("professional-blue")
  match_logo_colours    Boolean  @default(false)
  logo_uploaded         Boolean  @default(false)
  photos_uploaded       Boolean  @default(false)
  example_websites      String?  @default("")
  avoid_on_site         String?  @default("")

  // Step 5 — SEO & Location
  main_city             String
  full_service_area     String?  @default("")
  priority_locations    String?  @default("")
  seo_keywords          String?  @default("")
  service_pages         Boolean  @default(true)
  location_pages        Boolean  @default(true)

  // Step 6 — Conversion Details
  contact_number_to_show String? @default("")
  contact_email_to_show  String? @default("")
  contact_form           Boolean  @default(true)
  google_maps            Boolean  @default(true)
  testimonials_on_site   Boolean  @default(true)
  quote_request_form     Boolean  @default(true)
  booking_or_whatsapp    String   @default("none")

  // Step 7 — Add-ons & Final Details
  google_listing_option  Boolean  @default(false)
  branded_domain_option  Boolean  @default(false)
  additional_notes       String?  @default("")
  seasonal_offers        String?  @default("")
  competitors            String?  @default("")
  avoid_wording          String?  @default("")

  // Preview generated association
  previewId              String?  @default("")
  // AI-generated website HTML — stored for serving the preview iframe
  generatedHtml          String?  @default("")
}
